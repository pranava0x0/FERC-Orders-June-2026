# Secrets — never commit
.env
.env.local
credentials.json
secrets/

# Dependencies / build
node_modules/
dist/
__pycache__/
*.pyc

# Source PDFs and raw HTML snapshots are large / re-derivable — keep extracted text only.
# Exceptions (committed): the six order PDFs served by GitHub Pages for the page-citation
# links, and the DOE §403 letter the accuracy tests pin.
sources/archived/
*.pdf
*.docx
!docs/orders/*.pdf
!sources/pdf/doe-403-large-loads-letter.pdf
# RM26-4 comment bodies are re-derivable from their eLibrary accession links; commit the extracted
# text (sources/comments/files/<accession>/*.txt) + metadata + summaries, not the source binaries.

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Local preview config (machine-specific)
.claude/launch.json
